class BankAccount {
    String name;
    int accountNumber;
    double balance;

    static String bankName = "Sonali Bank";

    BankAccount(String n, int acc, double b) {
        name = n;
        accountNumber = acc;
        balance = b;
    }

    void show() {
        System.out.println("Account Number: " + accountNumber);
        System.out.println("Name: " + name);
        System.out.println("Balance: " + balance);
    }

    static void showBank() {
        System.out.println("Bank Name = " + bankName);
    }
}

// ADD THIS PART
public class BankAccountMain {
    public static void main(String[] args) {

        BankAccount obj1 = new BankAccount("Rahim", 1001, 5000);
        BankAccount obj2 = new BankAccount("Karim", 1002, 8000);

        BankAccount.showBank();

        obj1.show();
        System.out.println();
        obj2.show();
    }
}
